# -------------------------------------------------------
# Forum AI Notetaker — environment configuration
# Copy this file to .env before running the app and fill in the value.
# -------------------------------------------------------

# Required. Used to sign and verify JWT tokens for authentication.
# Any string works — do not change it after users have registered
# or their tokens will be invalidated.
JWT_SECRET_KEY=cs162-forum-ai-notetaker-2026

# Optional. Used to generate structured AI notes from transcripts.
# If left blank, the app falls back to a basic summary extracted
# from the transcript text — no Groq account needed.
GROQ_API_KEY=your_key_here

# Optional. How long login tokens stay valid (in hours). Defaults to 24.
JWT_EXPIRY_HOURS=24
